CREATE MEMORY TABLE PUBLIC.TINTERVENTIONS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,DATE TIMESTAMP,ENTITYSTATE VARCHAR(255),MINUTES INTEGER,UPDATEDAT TIMESTAMP,VERSION BIGINT,MECHANIC_ID VARCHAR(255),WORKORDER_ID VARCHAR(255),CONSTRAINT UNQ_TINTERVENTIONS_0 UNIQUE(DATE,WORKORDER_ID,MECHANIC_ID))
CREATE MEMORY TABLE PUBLIC.TPAYMENTMEANS(ID VARCHAR(255) NOT NULL PRIMARY KEY,DTYPE VARCHAR(31),ACCUMULATED DOUBLE,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,CLIENT_ID VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.TPAYROLLS(ID VARCHAR(255) NOT NULL PRIMARY KEY,BASESALARY DOUBLE NOT NULL,CREATEDAT TIMESTAMP,DATE DATE NOT NULL,ENTITYSTATE VARCHAR(255),EXTRASALARY DOUBLE NOT NULL,NICDEDUCTION DOUBLE NOT NULL,PRODUCTIVITYEARNING DOUBLE NOT NULL,TAXDEDUCTION DOUBLE NOT NULL,TRIENNIUMEARNING DOUBLE NOT NULL,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONTRACT_ID VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.TCLIENTS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,EMAIL VARCHAR(255),ENTITYSTATE VARCHAR(255),NAME VARCHAR(255),NIF VARCHAR(255),PHONE VARCHAR(255),SURNAME VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,CITY VARCHAR(255),STREET VARCHAR(255),ZIPCODE VARCHAR(255),CONSTRAINT UNQ_TCLIENTS_0 UNIQUE(NIF))
CREATE MEMORY TABLE PUBLIC.TPROFESSIONALGROUPS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),NAME VARCHAR(255) NOT NULL,PRODUCTIVITYRATE DOUBLE NOT NULL,TRIENNIUMPAYMENT DOUBLE NOT NULL,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONSTRAINT UNQ_TPROFESSIONALGROUPS_3 UNIQUE(NAME))
CREATE MEMORY TABLE PUBLIC.TVEHICLETYPES(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),NAME VARCHAR(255),PRICEPERHOUR DOUBLE,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONSTRAINT UNQ_TVEHICLETYPES_3 UNIQUE(NAME))
CREATE MEMORY TABLE PUBLIC.TWORKORDERS(ID VARCHAR(255) NOT NULL PRIMARY KEY,AMOUNT DOUBLE,CREATEDAT TIMESTAMP,DATE TIMESTAMP,DESCRIPTION VARCHAR(255),ENTITYSTATE VARCHAR(255),STATE VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,INVOICE_ID VARCHAR(255),MECHANIC_ID VARCHAR(255),VEHICLE_ID VARCHAR(255),CONSTRAINT UNQ_TWORKORDERS_0 UNIQUE(DATE,VEHICLE_ID))
CREATE MEMORY TABLE PUBLIC.TCREDITCARDS(ID VARCHAR(255) NOT NULL PRIMARY KEY,NUMBER VARCHAR(255),TYPE VARCHAR(255),VALIDTHRU DATE,CONSTRAINT UNQ_TCREDITCARDS_1 UNIQUE(NUMBER))
CREATE MEMORY TABLE PUBLIC.TINVOICES(ID VARCHAR(255) NOT NULL PRIMARY KEY,AMOUNT DOUBLE,CREATEDAT TIMESTAMP,DATE DATE,ENTITYSTATE VARCHAR(255),NUMBER BIGINT NOT NULL,STATE VARCHAR(255) NOT NULL,UPDATEDAT TIMESTAMP,VAT DOUBLE,VERSION BIGINT,CONSTRAINT UNQ_TINVOICES_5 UNIQUE(NUMBER))
CREATE MEMORY TABLE PUBLIC.TCONTRACTTYPES(ID VARCHAR(255) NOT NULL PRIMARY KEY,COMPENSATIONDAYSPERYEAR DOUBLE NOT NULL,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),NAME VARCHAR(255) NOT NULL,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONSTRAINT UNQ_TCONTRACTTYPES_4 UNIQUE(NAME))
CREATE MEMORY TABLE PUBLIC.TSPAREPARTS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CODE VARCHAR(255),CREATEDAT TIMESTAMP,DESCRIPTION VARCHAR(255),ENTITYSTATE VARCHAR(255),MAXSTOCK INTEGER,MINSTOCK INTEGER,PRICE DOUBLE,STOCK INTEGER,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONSTRAINT UNQ_TSPAREPARTS_1 UNIQUE(CODE))
CREATE MEMORY TABLE PUBLIC.TCONTRACTS(ID VARCHAR(255) NOT NULL PRIMARY KEY,ANNUALBASESALARY DOUBLE NOT NULL,CREATEDAT TIMESTAMP,ENDDATE DATE,ENTITYSTATE VARCHAR(255),SETTLEMENT DOUBLE NOT NULL,STARTDATE DATE NOT NULL,STATE VARCHAR(255) NOT NULL,TAXRATE DOUBLE NOT NULL,UPDATEDAT TIMESTAMP,VERSION BIGINT,CONTRACTTYPE_ID VARCHAR(255),MECHANIC_ID VARCHAR(255),PROFESSIONALGROUP_ID VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.TVOUCHERS(ID VARCHAR(255) NOT NULL PRIMARY KEY,AVAILABLE DOUBLE,CODE VARCHAR(255),DESCRIPTION VARCHAR(255),CONSTRAINT UNQ_TVOUCHERS_2 UNIQUE(CODE))
CREATE MEMORY TABLE PUBLIC.TSUBSTITUTIONS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),QUANTITY INTEGER,UPDATEDAT TIMESTAMP,VERSION BIGINT,INTERVENTION_ID VARCHAR(255),SPAREPART_ID VARCHAR(255),CONSTRAINT UNQ_TSUBSTITUTIONS_0 UNIQUE(SPAREPART_ID,INTERVENTION_ID))
CREATE MEMORY TABLE PUBLIC.TCASHES(ID VARCHAR(255) NOT NULL PRIMARY KEY)
CREATE MEMORY TABLE PUBLIC.TCHARGES(ID VARCHAR(255) NOT NULL PRIMARY KEY,AMOUNT DOUBLE,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,INVOICE_ID VARCHAR(255),PAYMENTMEAN_ID VARCHAR(255),CONSTRAINT UNQ_TCHARGES_0 UNIQUE(INVOICE_ID,PAYMENTMEAN_ID))
CREATE MEMORY TABLE PUBLIC.TVEHICLES(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),MAKE VARCHAR(255),MODEL VARCHAR(255),PLATENUMBER VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,CLIENT_ID VARCHAR(255),VEHICLETYPE_ID VARCHAR(255),CONSTRAINT UNQ_TVEHICLES_5 UNIQUE(PLATENUMBER))
CREATE MEMORY TABLE PUBLIC.TMECHANICS(ID VARCHAR(255) NOT NULL PRIMARY KEY,CREATEDAT TIMESTAMP,ENTITYSTATE VARCHAR(255),NAME VARCHAR(255),NIF VARCHAR(255),SURNAME VARCHAR(255),UPDATEDAT TIMESTAMP,VERSION BIGINT,CONSTRAINT UNQ_TMECHANICS_4 UNIQUE(NIF))
